---
const year = 2026;
const base = import.meta.env.BASE_URL; // e.g. "/emoria/"
---

<footer class="border-t border-[var(--color-cream-edge)] bg-[var(--color-cream-deep)]">
  <div class="mx-auto max-w-6xl px-6 py-14">
    <div class="flex flex-col gap-10 sm:flex-row sm:justify-between">
      <div class="max-w-sm">
        <p class="font-[var(--font-display)] text-2xl font-semibold">EMORIA</p>
        <p class="mt-3 text-[var(--color-ink-soft)]">
          A play-based way for children to recognise, name and talk about their feelings.
          Yubuu’s Feeling Wheel is where it begins.
        </p>
        <p class="mt-4 text-sm text-[var(--color-ink-faint)]">Made in Berlin · for kindergartens, schools and families</p>
      </div>

      <nav class="flex flex-col gap-2 text-[var(--color-ink-soft)]">
        <a href={base} class="hover:text-[var(--color-ink)]">Home</a>
        <a href={`${base}about`} class="hover:text-[var(--color-ink)]">About Cemil</a>
        <a href={`${base}contact`} class="hover:text-[var(--color-ink)]">Contact</a>
        <a href={`${base}legal`} class="hover:text-[var(--color-ink)]">Legal Notice</a>
      </nav>
    </div>

    <p class="mt-12 border-t border-[var(--color-cream-edge)] pt-6 text-sm text-[var(--color-ink-faint)]">
      © {year} EMORIA · Cemil Can Özkaya, Berlin. EMORIA launches to kindergartens in April 2027.
    </p>
  </div>
</footer>
