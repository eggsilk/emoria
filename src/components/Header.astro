---
// Site header for inner pages — matches the accordion top menu.
interface Props { current?: string }
const { current = '' } = Astro.props;
const base = import.meta.env.BASE_URL; // e.g. "/emoria/"

const links = [
  { href: `${base}about`, label: 'About' },
  { href: `${base}contact`, label: 'Contact' },
];
---

<header class="absolute inset-x-0 top-0 z-50">
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-5">
    <a href={base} class="font-[var(--font-display)] text-2xl font-semibold tracking-wide text-[var(--color-ink)]" aria-label="EMORIA home">
      EMORIA
    </a>
    <ul class="flex items-center gap-6">
      {links.map((l) => (
        <li>
          <a
            href={l.href}
            class:list={[
              'font-[var(--font-body)] text-[15px] font-medium text-[var(--color-ink)] transition',
              current === l.label ? 'opacity-100' : 'opacity-75 hover:opacity-100',
            ]}
          >
            {l.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>
