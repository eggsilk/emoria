---
import '@fontsource-variable/fredoka';
import '@fontsource-variable/rubik';
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  current?: string;
  overlayHeader?: boolean;
  hideChrome?: boolean;
}

const {
  title = 'EMORIA — Emotional Learning',
  description = "EMORIA is a play-based system that helps children recognise, name and talk about their feelings. Yubuu's Feeling Wheel is where it begins.",
  current = '',
  overlayHeader = false,
  hideChrome = false,
} = Astro.props;
const base = import.meta.env.BASE_URL; // e.g. "/emoria/"
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" href={`${base}img/logo.png`} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
  </head>
  <body>
    {!hideChrome && <Header overlay={overlayHeader} current={current} />}
    <main>
      <slot />
    </main>
    {!hideChrome && <Footer />}
  </body>
</html>
