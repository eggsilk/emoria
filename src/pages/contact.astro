---
import Base from '../layouts/Base.astro';
---

<Base title="Contact — EMORIA" current="Contact"
  description="Interested in bringing EMORIA to your kindergarten, or want to follow along? Get in touch with Cemil.">
  <article class="bg-[var(--color-cream)]">
    <div class="mx-auto max-w-2xl px-6 pb-10 pt-36 text-center">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[var(--color-brand)]">✦ Contact</p>
      <h1 class="mt-3 text-4xl sm:text-6xl">Say hello.</h1>
      <p class="mt-5 text-lg text-[var(--color-ink-soft)]">
        Whether you’re an educator curious about trying EMORIA in your Kita, or a parent who
        wants to follow along until it launches — write a line. Cemil reads every message.
      </p>
    </div>

    <div class="mx-auto max-w-xl px-6 pb-24">
      <form class="rounded-[2rem] border border-[var(--color-cream-edge)] bg-white/60 p-7 shadow-[var(--shadow-soft)] sm:p-9" data-contact>
        <div class="grid gap-5">
          <label class="block">
            <span class="text-sm font-medium text-[var(--color-ink)]">Your name</span>
            <input type="text" name="name" required
              class="mt-1.5 w-full rounded-[var(--radius-card)] border border-[var(--color-cream-edge)] bg-[var(--color-cream)] px-4 py-3 outline-none focus:border-[var(--color-brand)]" />
          </label>

          <label class="block">
            <span class="text-sm font-medium text-[var(--color-ink)]">Kindergarten or organisation <span class="font-normal text-[var(--color-ink-faint)]">(optional)</span></span>
            <input type="text" name="organisation"
              class="mt-1.5 w-full rounded-[var(--radius-card)] border border-[var(--color-cream-edge)] bg-[var(--color-cream)] px-4 py-3 outline-none focus:border-[var(--color-brand)]" />
          </label>

          <label class="block">
            <span class="text-sm font-medium text-[var(--color-ink)]">Email</span>
            <input type="email" name="email" required
              class="mt-1.5 w-full rounded-[var(--radius-card)] border border-[var(--color-cream-edge)] bg-[var(--color-cream)] px-4 py-3 outline-none focus:border-[var(--color-brand)]" />
          </label>

          <label class="block">
            <span class="text-sm font-medium text-[var(--color-ink)]">Your message</span>
            <textarea name="message" rows="4"
              class="mt-1.5 w-full rounded-[var(--radius-card)] border border-[var(--color-cream-edge)] bg-[var(--color-cream)] px-4 py-3 outline-none focus:border-[var(--color-brand)]"></textarea>
          </label>

          <button type="submit"
            class="rounded-[var(--radius-pill)] bg-[var(--color-brand)] px-7 py-3.5 font-[var(--font-body)] font-semibold text-white shadow-[var(--shadow-soft)] transition hover:bg-[var(--color-brand-deep)]">
            Send message
          </button>

          <p class="text-center text-sm text-[var(--color-ink-faint)]">
            Prefer email? Write to <a href="mailto:hello@emoria.de" class="underline decoration-[var(--color-cream-edge)] underline-offset-2 hover:text-[var(--color-ink)]">hello@emoria.de</a>
          </p>
        </div>
      </form>
      <p class="mt-4 text-center text-xs text-[var(--color-ink-faint)]">
        Draft note: this form isn’t wired to a backend yet — we’ll connect it to a
        GDPR-compliant handler (and confirm the real address) before launch.
      </p>
    </div>
  </article>
</Base>
