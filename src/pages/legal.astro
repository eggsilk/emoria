---
import Base from '../layouts/Base.astro';
// The German-law Impressum (§5 DDG), titled in English. Placeholder — fill with Cemil's real
// details before launch, and provide a German version for the live German site.
---

<Base title="Legal Notice — EMORIA" current=""
  description="Legal notice for EMORIA.">
  <article class="bg-[var(--color-cream)]">
    <div class="mx-auto max-w-2xl px-6 pb-24 pt-36">
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-[var(--color-brand)]">✦ Legal</p>
      <h1 class="mt-3 text-4xl sm:text-5xl">Legal Notice</h1>
      <p class="mt-4 rounded-[var(--radius-card)] bg-[var(--color-cream-deep)] px-4 py-3 text-sm text-[var(--color-ink-soft)]">
        Draft placeholder — to be completed with real details before the site goes live. German
        law requires a complete legal notice (Impressum, §5 DDG); a German version will be provided.
      </p>

      <div class="mt-10 space-y-8 text-[var(--color-ink-soft)]">
        <section>
          <h2 class="text-xl text-[var(--color-ink)]">Provider</h2>
          <p class="mt-2">
            Cemil Can Özkaya<br />
            EMORIA<br />
            [Street address]<br />
            [Postal code] Berlin<br />
            Germany
          </p>
        </section>

        <section>
          <h2 class="text-xl text-[var(--color-ink)]">Contact</h2>
          <p class="mt-2">
            Email: hello@emoria.de<br />
            [Telephone, optional]
          </p>
        </section>

        <section>
          <h2 class="text-xl text-[var(--color-ink)]">Responsible for content</h2>
          <p class="mt-2">Cemil Can Özkaya, address as above.</p>
        </section>

        <section>
          <h2 class="text-xl text-[var(--color-ink)]">Image credits</h2>
          <p class="mt-2">Illustrations and product photography © EMORIA. Character illustrations are draft / AI-assisted pending final professional artwork.</p>
        </section>
      </div>
    </div>
  </article>
</Base>
