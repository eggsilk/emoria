---
import '@fontsource-variable/fredoka';
import '@fontsource-variable/rubik';
import '../styles/global.css';

const base = import.meta.env.BASE_URL; // e.g. "/emoria/"

// Fixed left-to-right order. Exactly one is open; the rest are vertical strips
// sitting in their positional order (earlier = left of open, later = right).
const panels = [
  {
    id: 'home', tab: 'EMORIA', strip: '#2b2a28', bg: '#fff1e4', c: '#ff7673', ink: '#2b2a28',
    kind: 'home',
    eyebrow: '✦ Emotional learning, through play',
    title: 'Welcome to EMORIA',
    body: 'A little universe that helps children recognise, name and talk about their feelings. Pick a door →',
  },
  {
    id: 'meet', tab: 'Meet Yubuu', strip: '#02ae90', bg: '#eaf4ef', c: '#02ae90', ink: '#08312a',
    kind: 'story',
    hero: 'Meet Yubuu.',
    beats: [
      'Yubuu comes from a small planet far across the galaxy — a place where feelings glow in colour.',
      'They travel from world to world with their family, curious about absolutely everything.',
      'On some planets the creatures don’t know their feelings at all; on others, a single feeling rules everyone.',
      'Yubuu wants to understand them all. And that is exactly where you come in.',
    ],
  },
  {
    id: 'wheel', tab: "Yubuu's Feeling Wheel", strip: '#ff7673', bg: '#fff1e4', c: '#ff7673', ink: '#4a1f1d',
    kind: 'game', game: 'game/index.html',
    eyebrow: 'Play',
    title: 'Yubuu’s Feeling Wheel.',
    body: 'Give the wheel a spin.',
    cta: 'Play the wheel',
  },
  {
    id: 'why', tab: 'Why EMORIA?', strip: '#ea9f0e', bg: '#fae6bf', c: '#ea9f0e', ink: '#3d2a04',
    kind: 'why',
    eyebrow: 'The thinking',
    title: 'Why EMORIA?',
    body: 'Talking about feelings is a learned skill — and children rarely get a safe place to practise it. EMORIA turns emotional learning into play: no right or wrong answers, grounded in ten years of practice and current research. When a child can name what they feel, everything else — friendships, focus, resilience — gets a little easier.',
  },
];
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>EMORIA — Emotional Learning</title>
  <meta name="description" content="EMORIA is a play-based system that helps children recognise, name and talk about their feelings. Yubuu's Feeling Wheel is where it begins." />
  <meta name="generator" content={Astro.generator} />
  <link rel="icon" type="image/png" href={`${base}img/logo.png`} />
  <meta property="og:title" content="EMORIA — Emotional Learning" />
  <meta property="og:description" content="A play-based way for children to recognise, name and talk about their feelings." />
  <meta property="og:type" content="website" />
</head>
<body>
  <!-- TOP MENU — left edge aligns to the right of the strips left of the open panel -->
  <header class="topbar" data-topbar style="left:0;right:calc(3 * var(--stripw))">
    <button class="brand" data-open="home" aria-label="Back to start">EMORIA</button>
    <nav class="topnav">
      <a href={`${base}about`}>About</a>
      <a href={`${base}contact`}>Contact</a>
    </nav>
  </header>

  <div class="rail" data-rail>
    {panels.map((p, i) => (
      <section class="panel" class:list={[{ 'is-open': i === 0 }]} data-panel={p.id}
        style={`--strip:${p.strip};--bg:${p.bg};--c:${p.c};--ink:${p.ink}`}>

        <!-- collapsed strip -->
        <button class="strip" data-open={p.id} aria-label={p.tab}><span>{p.tab}</span></button>

        <!-- expanded content -->
        <div class="content">
          {p.kind === 'game' ? (
            <iframe class="game-frame" src={`${base}${p.game}`} title="Yubuu’s Feeling Wheel" loading="lazy"></iframe>
          ) : p.kind === 'story' ? (
            <div class="story" data-story>
              <div class="beat hero left is-shown" data-beat="0">
                <h2 class="s-hero">{p.hero}</h2>
                <p class="s-hint" data-hint>Scroll or click to continue →</p>
              </div>
              {p.beats.map((bt, i) => (
                <div class:list={['beat', i % 2 === 0 ? 'right' : 'left']} data-beat={i + 1}>
                  <p class="s-text">{bt}</p>
                </div>
              ))}
            </div>
          ) : p.kind === 'why' ? (
            <div class="why">
              <img class="why-yubuu" src={`${base}img/yubuu-cutout.png`} alt="Yubuu pointing" />
              <div class="why-text">
                <h2 class="why-hero">{p.title}</h2>
                <p class="why-body">{p.body}</p>
                <div class="why-links">
                  <a href={`${base}about`}>About Cemil →</a>
                  <a href={`${base}contact`}>Get in touch →</a>
                </div>
              </div>
            </div>
          ) : p.kind === 'home' ? (
            <div class="home-wrap">
              <div class="starfield" aria-hidden="true">
                <span class="star s1">✦</span><span class="star s2">✦</span><span class="star s3">✦</span>
                <span class="star s4">✦</span><span class="star s5">✦</span><span class="star s6">✦</span>
                <span class="star s7">✦</span><span class="star s8">✦</span><span class="star s9">✦</span>
                <span class="star s10">✦</span><span class="star s11">✦</span><span class="star s12">✦</span>
                <span class="star s13">✦</span><span class="star s14">✦</span><span class="star s15">✦</span>
                <span class="star s16">✦</span><span class="star s17">✦</span><span class="star s18">✦</span>
                <span class="star s19">✦</span><span class="star s20">✦</span><span class="star s21">✦</span>
                <span class="star s22">✦</span>
              </div>
              <div class="c-inner home">
                <div class="c-text">
                  <h1 class="home-title stg">{p.title}</h1>
                  <p class="home-tag stg">✦ Emotional learning, through play</p>
                </div>
                <div class="c-art home-art">
                  <div class="home-video-wrap">
                    <video class="home-video" autoplay loop muted playsinline preload="auto" aria-label="Yubuu flying a rocket">
                      <source src={`${base}video/kling_yubuu_rocket_no-bg.webm`} type="video/webm" />
                      <source src={`${base}video/kling_yubuu_rocket_no-bg.mov`} type="video/quicktime" />
                    </video>
                  </div>
                </div>
              </div>
            </div>
          ) : (
            <div class="c-inner">
              <div class="c-text">
                <p class="eyebrow stg">{p.eyebrow}</p>
                <h2 class="p-title stg" set:html={p.title}></h2>
                <p class="p-body stg">{p.body}</p>
                <button class="p-cta stg">{p.cta}</button>
              </div>
              <div class="c-art">
                <span class="p-planet stg"></span>
                <img class="art-yubuu stg" src={`${base}img/yubuu-cutout.png`} alt="Yubuu" />
              </div>
            </div>
          )}
        </div>
      </section>
    ))}
  </div>

  <script is:inline>
    (() => {
      const rail = document.querySelector('[data-rail]');
      const topbar = document.querySelector('[data-topbar]');
      const panels = [...rail.querySelectorAll('.panel')];
      const n = panels.length;

      function setOpen(id) {
        const idx = panels.findIndex((p) => p.dataset.panel === id);
        if (idx < 0) return;
        panels.forEach((p, i) => p.classList.toggle('is-open', i === idx));
        // menu starts to the right of the strips left of the open panel,
        // and ends to the left of the strips right of it.
        topbar.style.left = `calc(${idx} * var(--stripw))`;
        topbar.style.right = `calc(${n - 1 - idx} * var(--stripw))`;
      }

      // strip buttons + the logo (data-open="home") share the handler
      document.querySelectorAll('[data-open]').forEach((btn) =>
        btn.addEventListener('click', () => setOpen(btn.dataset.open)));

      setOpen('home');

      // ---- Meet Yubuu: click or scroll reveals the next box (page itself never scrolls) ----
      document.querySelectorAll('[data-story]').forEach((story) => {
        const panel = story.closest('.panel');
        const beats = [...story.querySelectorAll('.beat')];
        const hint = story.querySelector('[data-hint]');
        const last = beats.length - 1;
        let idx = 0;
        const isOpen = () => panel.classList.contains('is-open');

        function show(i) {
          i = Math.max(0, Math.min(last, i));
          if (i === idx) return;
          beats.forEach((b, k) => b.classList.toggle('is-shown', k <= i));
          idx = i;
          if (hint) {
            hint.classList.toggle('hide', idx >= last);
            hint.textContent = idx === 0 ? 'Scroll or click to continue →' : 'Keep going →';
          }
        }

        story.addEventListener('click', () => { if (isOpen()) show(idx + 1); });

        // scroll advances/retreats the reveal instead of scrolling the page
        let lock = 0;
        story.addEventListener('wheel', (e) => {
          if (!isOpen()) return;
          e.preventDefault();
          if (Math.abs(e.deltaY) < 8 || e.timeStamp - lock < 600) return;
          lock = e.timeStamp;
          show(e.deltaY > 0 ? idx + 1 : idx - 1);
        }, { passive: false });
      });
    })();
  </script>

  <style is:global>
    :root { --stripw: 4.75rem; }
    body { margin: 0; }

    /* TOP MENU */
    .topbar { position: fixed; top: 0; z-index: 40; height: 66px; display: flex; align-items: center;
      justify-content: space-between; padding: 0 clamp(1.2rem, 2.6vw, 2.2rem);
      transition: left .62s cubic-bezier(.72,0,.14,1), right .62s cubic-bezier(.72,0,.14,1); }
    .brand { background: none; border: 0; cursor: pointer; font-family: 'Fredoka Variable', sans-serif;
      font-weight: 600; font-size: 22px; letter-spacing: .02em; color: #2b2a28; }
    .topnav { display: flex; gap: 1.5rem; }
    .topnav a { font-family: 'Rubik Variable', sans-serif; font-weight: 500; font-size: 15px;
      color: #2b2a28; text-decoration: none; opacity: .78; transition: opacity .2s; }
    .topnav a:hover { opacity: 1; }

    .rail { display: flex; height: 100vh; width: 100vw; overflow: hidden; background: #fff1e4;
      font-family: 'Rubik Variable', sans-serif; }

    .panel { position: relative; flex: 0 0 auto; width: var(--stripw);
      transition: width .62s cubic-bezier(.72,0,.14,1); overflow: hidden; }
    .panel.is-open { width: calc(100vw - (3 * var(--stripw))); }

    /* collapsed strip */
    .strip { position: absolute; inset: 0; z-index: 3; width: 100%; height: 100%; border: 0; cursor: pointer;
      background: var(--strip); color: #fff; font-family: 'Fredoka Variable', sans-serif; font-weight: 600;
      font-size: 18px; letter-spacing: .01em; display: flex; align-items: center; justify-content: center;
      writing-mode: vertical-rl; text-orientation: mixed; transform: rotate(180deg);
      transition: opacity .35s ease, filter .3s ease; white-space: nowrap; }
    .strip:hover { filter: brightness(1.08); }
    .panel.is-open .strip { opacity: 0; pointer-events: none; }

    /* expanded content — fixed to the open width so it doesn't reflow while animating */
    .content { position: absolute; top: 0; left: 0; height: 100%; width: calc(100vw - (3 * var(--stripw)));
      background: var(--bg); opacity: 0; pointer-events: none; transition: opacity .3s ease; }
    .panel.is-open .content { opacity: 1; pointer-events: auto; transition-delay: .18s; }
    /* embedded self-contained game — fills the open panel, below the top menu */
    .game-frame { position: absolute; inset: 0; width: 100%; height: 100%; border: 0;
      padding-top: 66px; box-sizing: border-box; background: #fff1e4; }

    /* ---- Meet Yubuu: click / scroll reveals text boxes; all fit on one screen, no page scroll ---- */
    .story { position: absolute; inset: 0; overflow: hidden; cursor: pointer;
      padding: 92px 6vw 6vh; display: flex; flex-direction: column; justify-content: space-between; }
    .beat { max-width: min(58%, 660px);
      opacity: 0; transition: opacity .55s ease, transform .6s cubic-bezier(.2,.8,.2,1); }
    .beat.left  { align-self: flex-start; transform: translateX(-46px); }
    .beat.right { align-self: flex-end;  transform: translateX(46px); }
    .beat.is-shown { opacity: 1; transform: none; }
    /* hero: title + hint on one row so it stays short vertically */
    .beat.hero { max-width: none; display: flex; align-items: baseline; flex-wrap: wrap; gap: .3rem 1.5rem; }
    .s-hero { font-family: 'Fredoka Variable', sans-serif; font-weight: 600;
      font-size: clamp(44px, 6.2vw, 84px); line-height: .98; color: var(--ink); margin: 0; }
    .s-text { font-family: 'Fredoka Variable', sans-serif; font-weight: 500;
      font-size: clamp(21px, 2.4vw, 32px); line-height: 1.32; color: var(--ink); }
    .s-hint { font-family: 'Rubik Variable', sans-serif; font-size: 14px; color: #8a8378;
      margin: 0; white-space: nowrap; animation: hintpulse 1.9s ease-in-out infinite; }
    .s-hint.hide { animation: none; opacity: 0; transition: opacity .4s; }
    @keyframes hintpulse { 0%,100% { opacity: .55; } 50% { opacity: 1; } }
    @media (prefers-reduced-motion: reduce) {
      .beat { transition: opacity .3s; }
      .beat.left, .beat.right { transform: none; }
    }

    /* ---- Why EMORIA: Yubuu anchored bottom-left, pointing at wide text on the right ---- */
    .why { position: absolute; inset: 0; }
    .why-yubuu { position: absolute; left: 2%; bottom: 0; height: calc(100% - 80px); width: auto;
      max-width: none; z-index: 1; pointer-events: none;
      filter: drop-shadow(0 22px 34px rgba(43,42,40,.20)); }
    .why-text { position: absolute; right: 8.5%; top: 0; bottom: 0; width: 52%;
      display: flex; flex-direction: column; justify-content: flex-start; padding-top: 13vh; z-index: 2; }
    .why-eyebrow { font-family: 'Rubik Variable', sans-serif; font-weight: 600; letter-spacing: .14em;
      text-transform: uppercase; font-size: 13px; color: var(--c); }
    .why-hero { font-family: 'Fredoka Variable', sans-serif; font-weight: 600;
      font-size: clamp(46px, 6vw, 88px); line-height: 1; color: var(--ink); margin: .12em 0 .34em; }
    .why-body { font-family: 'Rubik Variable', sans-serif; font-size: clamp(18px, 1.65vw, 23px);
      line-height: 1.55; color: var(--ink); opacity: .86; max-width: 46ch; }
    .why-links { margin-top: 1.9rem; display: flex; gap: 1.6rem; flex-wrap: wrap; }
    .why-links a { font-family: 'Fredoka Variable', sans-serif; font-weight: 600; font-size: 16px;
      color: var(--c); text-decoration: none; filter: brightness(.85); }
    .why-links a:hover { text-decoration: underline; }
    @media (max-width: 900px) {
      .why-yubuu { opacity: .18; left: -6%; }
      .why-text { width: 88%; right: 6%; }
    }

    .c-inner { height: 100%; display: grid; grid-template-columns: 1.05fr .95fr; align-items: center;
      gap: 3vw; padding: 0 5.5vw; }
    .c-inner.home { grid-template-columns: 0.9fr 1.1fr; }

    .eyebrow { font-weight: 600; letter-spacing: .12em; text-transform: uppercase; font-size: 13px; color: var(--c); }
    .home-title { font-family: 'Fredoka Variable', sans-serif; font-weight: 600; font-size: clamp(40px, 5.1vw, 78px); line-height: .98; color: var(--ink); margin: .1em 0 .3em; }
    .home-tag { font-family: 'Rubik Variable', sans-serif; font-weight: 600; font-size: clamp(15px, 1.5vw, 20px); letter-spacing: .04em; color: var(--c); margin: 0 0 .8em; }
    .home-sub { font-size: 19px; line-height: 1.6; color: #57534c; max-width: 26rem; }
    .p-title { font-family: 'Fredoka Variable', sans-serif; font-weight: 600; font-size: clamp(34px, 4.6vw, 62px); line-height: 1.03; color: var(--ink); margin: .22em 0; }
    .p-body { font-size: 18px; line-height: 1.6; color: var(--ink); opacity: .82; max-width: 26rem; }
    .p-cta { margin-top: 1.6rem; border: 0; cursor: pointer; background: var(--c); color: #fff;
      font-family: 'Fredoka Variable', sans-serif; font-weight: 600; font-size: 16px; padding: .8rem 1.7rem; border-radius: 999px; }

    .c-art { position: relative; height: 62%; }
    /* home landing: Yubuu rocket video (transparent) replaces the static mascot */
    .home-art { height: 100%; display: flex; align-items: center; justify-content: center; }
    /* wrapper carries the one-shot fly-in from the left; the inner video keeps floating */
    .home-video-wrap { width: min(80%, 440px); transform: translateX(-135vw); opacity: 0; will-change: transform; }
    .panel.is-open .home-video-wrap { animation: flyIn 1.15s cubic-bezier(.16,.7,.24,1) 1.2s forwards; }
    .home-video { display: block; width: 100%; height: auto;
      filter: drop-shadow(0 24px 34px rgba(43,42,40,.16)); animation: hfloat 6s ease-in-out infinite; }
    @keyframes hfloat { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-16px); } }
    @keyframes flyIn { 0% { transform: translateX(-135vw) rotate(-8deg); opacity: 0; }
      55% { opacity: 1; } 100% { transform: translateX(0) rotate(0); opacity: 1; } }
    @media (prefers-reduced-motion: reduce) {
      .home-video { animation: none; }
      .home-video-wrap, .panel.is-open .home-video-wrap { animation: none; transform: none; opacity: 1; }
    }
    .art-yubuu { position: absolute; bottom: -16%; left: 50%; transform: translateX(-50%); height: 128%;
      filter: drop-shadow(0 18px 30px rgba(43,42,40,.18)); }
    .art-yubuu.point { height: 118%; }
    .p-planet { position: absolute; top: 4%; right: 8%; width: 88px; height: 88px; border-radius: 50%;
      background: radial-gradient(circle at 38% 32%, #fff, color-mix(in srgb, var(--c) 55%, #fff) 55%, var(--c));
      box-shadow: 0 12px 30px rgba(0,0,0,.12); }
    /* home starfield — scattered twinkling stars behind the whole panel */
    .home-wrap { position: absolute; inset: 0; }
    .starfield { position: absolute; inset: 0; z-index: 0; pointer-events: none; overflow: hidden; }
    .c-inner.home { position: relative; z-index: 1; }
    .star { position: absolute; color: var(--c); line-height: 1;
      animation: twinkle 3.4s ease-in-out infinite; }
    @keyframes twinkle { 0%,100% { opacity: .22; transform: scale(.85); }
      50% { opacity: .8; transform: scale(1.15); } }
    .starfield .star:nth-child(4n)   { animation-delay: .4s; }
    .starfield .star:nth-child(4n+1) { animation-delay: 1.1s; }
    .starfield .star:nth-child(4n+2) { animation-delay: 1.9s; }
    .starfield .star:nth-child(4n+3) { animation-delay: 2.6s; }
    .s1 { top: 7%;  left: 4%;  font-size: 22px; } .s2  { top: 14%; left: 21%; font-size: 13px; }
    .s3 { top: 6%;  left: 39%; font-size: 16px; } .s4  { top: 11%; left: 60%; font-size: 12px; }
    .s5 { top: 8%;  left: 81%; font-size: 21px; } .s6  { top: 21%; left: 92%; font-size: 14px; }
    .s7 { top: 29%; left: 11%; font-size: 15px; } .s8  { top: 39%; left: 29%; font-size: 11px; }
    .s9 { top: 33%; left: 51%; font-size: 25px; } .s10 { top: 45%; left: 73%; font-size: 13px; }
    .s11{ top: 52%; left: 90%; font-size: 17px; } .s12 { top: 59%; left: 7%;  font-size: 19px; }
    .s13{ top: 67%; left: 25%; font-size: 12px; } .s14 { top: 73%; left: 45%; font-size: 15px; }
    .s15{ top: 81%; left: 63%; font-size: 23px; } .s16 { top: 87%; left: 83%; font-size: 13px; }
    .s17{ top: 77%; left: 5%;  font-size: 14px; } .s18 { top: 90%; left: 33%; font-size: 18px; }
    .s19{ top: 46%; left: 15%; font-size: 12px; } .s20 { top: 24%; left: 45%; font-size: 14px; }
    .s21{ top: 62%; left: 54%; font-size: 12px; } .s22 { top: 84%; left: 14%; font-size: 16px; }

    /* staggered reveal */
    .stg { opacity: 0; transform: translateY(22px); }
    .panel.is-open .stg { opacity: 1; transform: none; transition: opacity .6s ease, transform .6s cubic-bezier(.2,.7,.2,1); }
    .panel.is-open .eyebrow { transition-delay: .30s; }
    .panel.is-open .home-title, .panel.is-open .p-title { transition-delay: .38s; }
    .panel.is-open .home-sub, .panel.is-open .p-body { transition-delay: .48s; }
    /* home: sequenced title -> tagline, then video flies in */
    .panel.is-open .home-title { transition-delay: .50s; }
    .panel.is-open .home-tag { transition-delay: .80s; }
    .panel.is-open .p-cta { transition-delay: .58s; }
    .panel.is-open .c-art, .panel.is-open .art-yubuu, .panel.is-open .p-planet { transition-delay: .44s; }

    @media (max-width: 820px) {
      :root { --stripw: 3rem; }
      .content { width: calc(100vw - (3 * var(--stripw))); }
      .c-inner, .c-inner.home { grid-template-columns: 1fr; }
      .c-art { display: none; }
      .strip { font-size: 13px; }
    }
  </style>
</body>
</html>
