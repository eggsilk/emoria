---
import Base from '../layouts/Base.astro';

const src = '/video/kling_yubuu_rocket_no-bg.webm';
---

<Base title="Yubuu Rocket — video preview" hideChrome={true}>
  <div class="preview">
    <!-- SPACE: entry context -->
    <section class="stage stage--space">
      <div class="stars"></div>
      <div class="stage__label">Entry context · space-dark</div>
      <video class="hero-video float" src={src} autoplay loop muted playsinline></video>
    </section>

    <!-- CREAM: warm world context -->
    <section class="stage stage--cream">
      <div class="stage__label stage__label--dark">Warm world · cream</div>
      <video class="hero-video float float--slow" src={src} autoplay loop muted playsinline></video>
      <div class="ground-shadow"></div>
    </section>

    <!-- SIDE BY SIDE small -->
    <section class="stage stage--split">
      <div class="split split--cream">
        <video class="mini" src={src} autoplay loop muted playsinline></video>
      </div>
      <div class="split split--space">
        <div class="stars stars--dim"></div>
        <video class="mini" src={src} autoplay loop muted playsinline></video>
      </div>
    </section>
  </div>
</Base>

<style>
  main { margin: 0; }
  .preview { display: flex; flex-direction: column; }

  .stage {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .stage__label {
    position: absolute;
    top: 1.5rem;
    left: 1.5rem;
    font-family: var(--font-display);
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: rgba(244, 235, 208, 0.7);
    z-index: 5;
  }
  .stage__label--dark { color: var(--color-ink-faint); }

  /* Space nebula */
  .stage--space {
    background:
      radial-gradient(120% 90% at 50% 15%, var(--color-space-3) 0%, var(--color-space-2) 35%, var(--color-space) 75%);
  }
  .stars {
    position: absolute; inset: 0;
    background-image:
      radial-gradient(1.5px 1.5px at 20% 30%, var(--color-star) 50%, transparent),
      radial-gradient(1.5px 1.5px at 70% 20%, #fff 50%, transparent),
      radial-gradient(1px 1px at 40% 70%, var(--color-star) 50%, transparent),
      radial-gradient(1px 1px at 85% 60%, #fff 50%, transparent),
      radial-gradient(1.5px 1.5px at 60% 80%, var(--color-star) 50%, transparent),
      radial-gradient(1px 1px at 15% 85%, #fff 50%, transparent),
      radial-gradient(1px 1px at 90% 35%, var(--color-star) 50%, transparent),
      radial-gradient(1.5px 1.5px at 33% 15%, #fff 50%, transparent);
    opacity: 0.8;
  }
  .stars--dim { opacity: 0.5; }

  /* Cream world */
  .stage--cream { background: var(--color-cream); }
  .ground-shadow {
    position: absolute;
    bottom: 16%;
    width: 40%;
    height: 40px;
    background: radial-gradient(ellipse at center, rgba(43,42,40,0.14), transparent 70%);
    filter: blur(6px);
    z-index: 1;
  }

  .hero-video {
    position: relative;
    z-index: 2;
    width: min(70vw, 780px);
    height: auto;
    filter: drop-shadow(0 24px 40px rgba(0,0,0,0.28));
  }
  .stage--cream .hero-video {
    filter: drop-shadow(0 20px 30px rgba(43,42,40,0.18));
  }

  /* Split section */
  .stage--split { min-height: 70vh; padding: 0; }
  .split {
    flex: 1;
    align-self: stretch;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }
  .split--cream { background: var(--color-cream-deep); }
  .split--space {
    background: radial-gradient(120% 120% at 50% 40%, var(--color-space-2), var(--color-space));
  }
  .mini { position: relative; z-index: 2; width: 80%; height: auto; }

  /* Gentle float */
  .float { animation: float 5s ease-in-out infinite; }
  .float--slow { animation-duration: 7s; }
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-18px); }
  }
  @media (prefers-reduced-motion: reduce) {
    .float { animation: none; }
  }
</style>
